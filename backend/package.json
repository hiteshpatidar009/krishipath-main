  "scripts": {
    "dev": "tsx watch -r tsconfig-paths/register src/index.ts",
    "db:check": "tsx -r tsconfig-paths/register src/infrastructure/database/postgres/postgres-connectivity.check.ts",
    "db:drift": "tsx -r tsconfig-paths/register src/infrastructure/database/postgres/schema-drift.check.ts",
    "build": "node --max-old-space-size=2048 node_modules/typescript/lib/tsc.js",
    "start": "tsx dist/index.js",
    "postinstall": "npm run build",
    "test:raw": "vitest run",
    "test": "vitest run && tsx src/shared/testing/reporters/master-report.ts",
    "test:watch": "vitest",
    "test:enterprise": "vitest run && vitest run && tsx src/shared/testing/reporters/master-report.ts",
    "test:coverage": "vitest run --coverage",
    "test:auth": "tsx -r tsconfig-paths/register test/modules/auth/index.ts"
  },
