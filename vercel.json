{
  "buildCommand": "npm --prefix KrishiPath_com/frontend run build",
  "outputDirectory": "KrishiPath_com/frontend/dist",
  "installCommand": "npm --prefix KrishiPath_com/frontend install",
  "env": {
    "NODE_ENV": "production"
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
